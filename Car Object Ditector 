        "camera_data = [\n",
        "    [12, 15, 8, 22],  # कैमरा 1 (Front) की रीडिंग्स\n",
        "    [5, 18, 14, 25],  # कैमरा 2 (Rear) की रीडिंग्स\n",
        "    [9, 11, 3, 16]    # कैमरा 3 (Side) की रीडिंग्स\n",
        "]\n",
        "\n",
        "minimum_num = camera_data[0][0]\n",
        "\n",
        "for i in camera_data:\n",
        "    for j in i:\n",
        "        if j < minimum_num:\n",
        "            minimum_num = j\n",
        "\n",
        "print(f\"min number from the list is {minimum_num}\")\n",
        "\n",
        "if minimum_num <= 5 and minimum_num > 0:\n",
        "   print(f\"CRITICAL ALERT: Emergency braking required! Object at {minimum_num} meters.\")\n",
        "elif minimum_num > 5:\n",
        "   print(\"System Safe !!\")\n",
        "else:\n",
        "   print(\"Wrong Reading !!\")"
