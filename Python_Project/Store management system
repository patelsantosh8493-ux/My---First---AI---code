      "source": [
        "# ==========================================\n",
        "# PROJECT 1: NAMAN ELECTRIC INVENTORY DATA\n",
        "# ==========================================\n",
        "\n",
        "# 1. MAIN INVENTORY (Dictionary)\n",
        "# Key: Appliance Name (String)\n",
        "# Value: Another Dictionary with 'price' (Float) and 'stock' (Integer)\n",
        "inventory = {\n",
        "    \"High-Speed Fan\": {\"price\": 1200.50, \"stock\": 15},\n",
        "    \"Digital Iron\": {\"price\": 850.00, \"stock\": 8},\n",
        "    \"LED Torch\": {\"price\": 250.25, \"stock\": 25},\n",
        "    \"Air Cooler\": {\"price\": 4500.00, \"stock\": 5},\n",
        "    \"Mixer Grinder\": {\"price\": 1850.75, \"stock\": 12}\n",
        "                    }\n",
        "\n",
        "# 2. UNIQUE CUSTOMERS REGISTER (Set)\n",
        "# इसमें केवल यूनीक ग्राहकों के नाम स्टोर होंगे (कोई डुप्लिकेट नहीं)\n",
        "unique_customers = {\"Satyam\", \"Ramesh\", \"Amit\"}\n",
        "\n",
        "# 3. FIXED BUSINESS RULES (Tuple)\n",
        "# टैक्स स्लैब और डिस्काउंट कोड्स जो कभी नहीं बदलेंगे (Immutable)\n",
        "# Format: (GST_PERCENTAGE, DISCOUNT_CODE, DISCOUNT_PERCENTAGE)\n",
        "TAX_AND_DISCOUNT_RULES = (18.0, \"NAMAN_ELEC_10\", 10.0)\n",
        "\n",
        "# 4. CURRENT TRANSACTION CART (List of Dictionaries)\n",
        "# टेस्ट करने के लिए एक सैंपल कार्ट (ग्राहक क्या-क्या खरीद रहा है र कितनी मात्रा में)\n",
        "current_cart = [\n",
        "    {\"item\": \"High-Speed Fan\", \"quantity\": 2},\n",
        "    {\"item\": \"LED Torch\", \"quantity\": 3}\n",
        "        ]\n",
        "\n",
        "def check_stock():\n",
        "    for i in current_cart:\n",
        "        if i[\"quantity\"] <= inventory[i[\"item\"]][\"stock\"]:\n",
        "             print(f\"{i[\"item\"]} purchasing successful\")\n",
        "        else:\n",
        "             print(f\"{i[\"item\"]} is out of stock\")\n",
        "\n",
        "\n",
        "def generate_bill():\n",
        "    for i in current_cart:\n",
        "         base_price = inventory[i[\"item\"]][\"price\"]*i[\"quantity\"]\n",
        "\n",
        "         discounted_price = base_price - ((base_price * TAX_AND_DISCOUNT_RULES[2]) / 100)\n",
        "\n",
        "         tax_amount = ((discounted_price * TAX_AND_DISCOUNT_RULES[0]) / 100)\n",
        "         final_bill = discounted_price + tax_amount\n",
        "\n",
        "         print(f\"\\nसामान: {i[\"item\"]} \\nकीमत: {inventory[i[\"item\"]][\"price\"]} \\nमात्रा: {i[\"quantity\"]} पीस \\nआधार कीमत: {base_price} \\nडिस्काउंट: Rs {discounted_price :.2f} \\nटैक्स (GST): +Rs {tax_amount :.2f} \\nकुल चुकाने हैं: Rs {final_bill:.2f}\")\n",
        "\n",
        "\n",
        "\n",
        "def update_inventory():\n",
        "    for i in current_cart:\n",
        "         inventory[i[\"item\"]][\"stock\"] = inventory[i[\"item\"]][\"stock\"] - i[\"quantity\"]\n",
        "\n",
        "\n",
        "check_stock()\n",
        "generate_bill()\n",
        "update_inventory()\n",
        "\n",
        "print(inventory)"
